{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "cropwatch",
      "runtimeExecutable": ".venv/bin/uvicorn",
      "runtimeArgs": ["app.main:app", "--host", "127.0.0.1", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "cropwatch-static",
      "runtimeExecutable": ".venv/bin/python",
      "runtimeArgs": ["-m", "http.server", "8095", "--directory", "docs"],
      "port": 8095
    }
  ]
}
